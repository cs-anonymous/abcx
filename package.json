{
	"name": "abc-tools",
	"displayName": "ABC Tools",
	"description": "Preview and play ABC files in Visual Studio Code",
	"version": "0.2.4",
	"license": "SEE LICENSE IN LICENSE.md",
	"publisher": "ishiharaf",
	"author": {
		"name": "Ishihara Felipe"
	},
	"icon": "media/logo.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/ishiharaf/abc"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"abc",
		"notation",
		"music"
	],
	"engines": {
		"vscode": "^1.76.0"
	},
	"activationEvents": [
		"onLanguage:abc",
		"onLanguage:abcx",
		"onCommand:abc.exportMidi",
		"onCommand:abc.showPreview"
	],
	"main": "src/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "abc",
				"aliases": [
					"ABC"
				],
				"extensions": [
					".abc"
				]
			},
			{
				"id": "abcx",
				"aliases": [
					"ABCX"
				],
				"extensions": [
					".abcx"
				]
			}
		],
		"grammars": [
			{
				"language": "abc",
				"scopeName": "source.abc",
				"path": "config/abc.tmGrammar.json"
			},
			{
				"language": "abcx",
				"scopeName": "source.abcx",
				"path": "config/abc.tmGrammar.json"
			}
		],
		"commands": [
			{
				"title": "Export MIDI",
				"command": "abc.exportMidi",
				"category": "ABC",
				"when": "editorLangId == abc || editorLangId == abcx",
				"icon": {
					"light": "icons/light/new-file.svg",
					"dark": "icons/dark/new-file.svg"
				}
			},
			{
				"title": "Show Preview",
				"command": "abc.showPreview",
				"category": "ABC",
				"when": "editorLangId == abc || editorLangId == abcx",
				"icon": {
					"light": "icons/light/preview.svg",
					"dark": "icons/dark/preview.svg"
				}
			}
		],
		"snippets": [
			{
				"language": "abc",
				"path": "config/snippets.json"
			},
			{
				"language": "abcx",
				"path": "config/snippets.json"
			}
		],
		"menus": {
			"editor/title": [
				{
					"when": "resourceLangId == abc || resourceLangId == abcx",
					"command": "abc.exportMidi",
					"group": "navigation"
				},
				{
					"when": "resourceLangId == abc || resourceLangId == abcx",
					"command": "abc.showPreview",
					"group": "navigation"
				}
			]
		}
	}
}
