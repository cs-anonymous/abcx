{
	"name": "abcx-tools",
	"displayName": "ABCX Tools",
	"description": "Preview, play and edit ABC/ABCX music notation with multi-voice support",
	"version": "0.3.3",
	"license": "SEE LICENSE IN LICENSE.md",
	"publisher": "YeSun",
	"author": {
		"name": "Ishihara Felipe"
	},
	"icon": "media/logo.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/ishiharaf/abc"
	},
	"categories": [
		"Programming Languages",
		"Other"
	],
	"keywords": [
		"abc",
		"abcx",
		"music",
		"notation",
		"score",
		"midi",
		"playback"
	],
	"engines": {
		"vscode": "^1.80.0"
	},
	"activationEvents": [
		"onLanguage:abc",
		"onLanguage:abcx"
	],
	"main": "src/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "abc",
				"aliases": [
					"ABC"
				],
				"extensions": [
					".abc"
				],
				"iconReferences": {
					"light": "icons/light/abc.svg",
					"dark": "icons/dark/abc.svg"
				}
			},
			{
				"id": "abcx",
				"aliases": [
					"ABCX"
				],
				"extensions": [
					".abcx"
				],
				"iconReferences": {
					"light": "icons/light/abc.svg",
					"dark": "icons/dark/abc.svg"
				}
			}
		],
		"configurationDefaults": {
			"[abcx]": {
				"editor.tokenColorCustomizations": {
					"textMateRules": [
						{
							"scope": "keyword.control.phrase.abc",
							"settings": {
								"foreground": "#4EC9B0",
								"fontStyle": "bold"
							}
						},
						{
							"scope": "constant.numeric.phrase.abc",
							"settings": {
								"foreground": "#4EC9B0"
							}
						},
						{
							"scope": "keyword.control.measure.abc",
							"settings": {
								"foreground": "#DCDCAA",
								"fontStyle": "bold"
							}
						},
						{
							"scope": "constant.numeric.measure.abc",
							"settings": {
								"foreground": "#DCDCAA"
							}
						}
					]
				}
			}
		},
		"grammars": [
			{
				"language": "abc",
				"scopeName": "source.abc",
				"path": "config/abc.tmGrammar.json"
			},
			{
				"language": "abcx",
				"scopeName": "source.abcx",
				"path": "config/abcx.tmGrammar.json"
			}
		],
		"commands": [
			{
				"title": "Export MIDI",
				"command": "abc.exportMidi",
				"category": "ABC",
				"when": "editorLangId == abc || editorLangId == abcx",
				"icon": {
					"light": "icons/light/new-file.svg",
					"dark": "icons/dark/new-file.svg"
				}
			},
			{
				"title": "Show Preview",
				"command": "abc.showPreview",
				"category": "ABC",
				"when": "editorLangId == abc || editorLangId == abcx",
				"icon": {
					"light": "icons/light/preview.svg",
					"dark": "icons/dark/preview.svg"
				}
			},
			{
				"title": "Smart Enter",
				"command": "abcx.smartEnter",
				"category": "ABCX",
				"when": "editorLangId == abcx"
			}
		],
		"snippets": [
			{
				"language": "abc",
				"path": "config/snippets.json"
			},
			{
				"language": "abcx",
				"path": "config/snippets.json"
			}
		],
		"menus": {
			"editor/title": [
				{
					"when": "resourceLangId == abc || resourceLangId == abcx",
					"command": "abc.exportMidi",
					"group": "navigation"
				},
				{
					"when": "resourceLangId == abc || resourceLangId == abcx",
					"command": "abc.showPreview",
					"group": "navigation"
				}
			]
		},
		"keybindings": [
			{
				"command": "abcx.smartEnter",
				"key": "ctrl+enter",
				"when": "editorTextFocus && editorLangId == abcx"
			}
		]
	},
	"devDependencies": {
		"@vscode/vsce": "^3.9.1"
	},
	"galleryBanner": {
		"theme": "dark"
	},
	"dependencies": {
		"jsdom": "^29.1.1"
	}
}
